---
import Layout from "../layouts/root.astro";

import { ArrowRight } from "@lucide/astro";
---

<Layout>
    <main class="flex-1">
        <!-- Hero -->
        <section class="relative overflow-hidden">
            {/* Background grid pattern */}
            <div
                class="absolute inset-0 -z-10 bg-[linear-gradient(to_right,#1a1a1a_1px,transparent_1px),linear-gradient(to_bottom,#1a1a1a_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_110%)]"
            >
            </div>

            <div
                class="mx-auto max-w-7xl px-4 py-24 sm:px-6 sm:py-32 lg:px-8 lg:py-40"
            >
                <div class="flex flex-col items-center text-center">
                    {/* Main heading */}
                    <h1
                        class="max-w-4xl text-balance text-4xl font-bold tracking-tight sm:text-5xl md:text-6xl lg:text-7xl"
                    >
                        <span class="text-foreground">One account.</span>{" "}
                        <span class="text-muted-foreground"
                            >Endless possibilities.</span
                        >
                    </h1>

                    {/* Subheading */}
                    <p
                        class="mt-6 max-w-2xl text-pretty text-lg leading-relaxed text-muted-foreground sm:text-xl"
                    >
                        Veblex is your unified digital ecosystem. Track your
                        fitness, organize your schedule, manage your
                        entertainment, and more - all connected through a single
                        secure Veblex account.
                    </p>

                    {/* CTA Buttons */}
                    <div
                        class="mt-10 grid grid-cols-1 items-center gap-4 sm:grid-cols-2"
                    >
                        <button
                            class="cursor-pointer flex items-center gap-2 bg-foreground text-background rounded-md py-2 px-6"
                        >
                            Create your Veblex account
                            <ArrowRight class="size-4" />
                        </button>
                        <button
                            class="cursor-pointer rounded-md py-2 px-6 border"
                            >Explore our services</button
                        >
                    </div>

                    {/* Stats */}
                    <div
                        class="mt-16 flex flex-col flex-wrap gap-8 border-t border-border pt-10 sm:gap-12 justify-center sm:flex-row"
                    >
                        <div class="flex flex-col items-center">
                            <span
                                class="text-3xl font-bold text-foreground sm:text-4xl"
                                >4+</span
                            >
                            <span class="mt-1 text-sm text-muted-foreground"
                                >Connected Services</span
                            >
                        </div>
                        <div class="flex flex-col items-center">
                            <span
                                class="text-3xl font-bold text-foreground sm:text-4xl"
                                >1</span
                            >
                            <span class="mt-1 text-sm text-muted-foreground"
                                >Account Needed</span
                            >
                        </div>
                        <div class="flex flex-col items-center">
                            <span
                                class="text-3xl font-bold text-foreground sm:text-4xl"
                                >100%</span
                            >
                            <span class="mt-1 text-sm text-muted-foreground"
                                >Secure SSO</span
                            >
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>
</Layout>
