---
import {
    Dumbbell,
    Calendar,
    Shield,
    Clapperboard,
    ArrowRight,
    ChevronRight,
} from "@lucide/astro";

export const partial = true;

const floatingIcons = [
    {
        icon: Dumbbell,
        color: "bg-chart-1",
        position: "top-[-30%] left-[-10%]",
        delay: "0s",
    },
    {
        icon: Calendar,
        color: "bg-chart-2",
        position: "top-[-10%] right-[0%]",
        delay: "0.5s",
    },
    {
        icon: Shield,
        color: "bg-chart-3",
        position: "top-[120%] left-[-20%]",
        delay: "1s",
    },
    {
        icon: Clapperboard,
        color: "bg-chart-4",
        position: "top-[120%] right-[-20%]",
        delay: "1.5s",
    },
];
---

<section
    class="relative min-h-screen flex flex-col items-center justify-center"
>
    <div
        class="container grid grid-cols-1 xl:grid-cols-2 px-4 py-12 sm:py-18 sm:px-6 lg:px-8 relative"
    >
        <div class="flex flex-col">
            {/* Main heading */}
            <h1
                class="text-balance text-5xl md:text-6xl font-bold leading-tight tracking-tight text-foreground"
            >
                Your digital life,<br />
                <span class="text-gradient">finally connected.</span>
            </h1>

            {/* Subheading */}
            <p
                class="my-8 text-pretty text-base leading-relaxed text-muted-foreground sm:text-xl"
            >
                We got tired of juggling a million apps. So we built something
                better. One account. Four awesome services. Zero headaches.
                Track your gains, plan your days, binge your shows - all in one
                place.
            </p>

            {/* CTA Buttons */}
            <div class="grid sm:flex items-center gap-4">
                <a
                    class="cursor-pointer flex items-center justify-between gap-2 rounded-lg py-3 px-6 sm:px-12 font-medium text-lg hover:bg-primary/90 bg-primary text-primary-foreground"
                    href="#"
                >
                    Create Your Account
                    <ArrowRight class="size-5" />
                </a>
                <a
                    class="cursor-pointer flex items-center justify-between gap-2 rounded-lg py-3 px-6 sm:px-12 font-medium text-lg hover:bg-primary/90 border"
                    href="#services"
                >
                    Explore services
                    <ChevronRight class="size-5" />
                </a>
            </div>

            <div class="mx-auto absolute inset-0 hidden">
                {/* Floating app icons */}
                {
                    false &&
                        floatingIcons.map((item) => (
                            <div
                                class={`absolute hidden lg:flex ${item.position} size-16 items-center justify-center rounded-2xl ${item.color} text-primary-foreground shadow-xl animate-bounce`}
                                style={{
                                    animationDelay: item.delay,
                                    animationDuration: "3s",
                                }}
                                aria-hidden="true"
                            >
                                <item.icon class="size-7" />
                            </div>
                        ))
                }
            </div>
        </div>

        <div class="flex flex-col items-center justify-center"></div>

        {/* Decorative background shapes */}
        <div class="hidden xl:block absolute inset-0 -z-10" aria-hidden="true">
            <div
                class="absolute top-1/2 -left-1/24 size-80 rounded-full bg-primary/15 blur-3xl"
            >
            </div>
            <div
                class="absolute bottom-1/2 right-1 size-96 rounded-full bg-accent/50 blur-3xl"
            >
            </div>
        </div>
    </div>

    {
        /*
        <div
        class="absolute bottom-32 right-[50%] translate-x-[50%] animate-bounce flex gap-1 text-muted-foreground text-sm"
        style={{ animationDuration: "3s" }}
        aria-hidden="true"
    >
        <Mouse class="size-5" />
        <span>Scroll for more</span>
    </div>
    */
    }
</section>
