---
import { cn } from "@/lib/utils";
import { Menu, X } from "@lucide/astro";

// Mock auth state - in a real app this would come from Veblex Auth
const mockUser = null; // Set to { name: "John Doe", email: "john@example.com", avatar: "" } to test logged in state
const user = mockUser;

const pathname = new URL(Astro.request.url).pathname;

const isCurrentPage = (page: string) => {
    if (page === "home") return pathname === "/";
    return pathname.startsWith(`/${page}`);
};
---

<header
    class="sticky top-0 z-50 w-full bg-background/95 backdrop-blur supports-backdrop-filter:bg-background/60"
>
    <div
        class="mx-auto flex h-16 container items-center justify-between px-4 sm:px-6 lg:px-8 gap-4"
    >
        <a href="/" class="flex w-26">
            <img
                src="/images/brand/logo/icons/svg/veblex-logo_full-light.svg"
                alt="Veblex"
            />
        </a>

        <div class="flex items-center gap-4">
            <!-- Desktop nav -->
            <nav class="hidden items-center gap-1 md:flex justify-self-center">
                <a
                    href="/services"
                    class={cn(
                        "flex py-2 px-4 text-muted-foreground hover:text-foreground",
                        isCurrentPage("services") && "text-foreground",
                    )}>Services</a
                >
                <a
                    href="/about"
                    class={cn(
                        "flex py-2 px-4 text-muted-foreground hover:text-foreground",
                        isCurrentPage("about") && "text-foreground",
                    )}>About</a
                >
            </nav>

            <!-- Auth buttons / profile -->
            <div class="flex items-center gap-4 justify-self-end ml-auto">
                <div class="hidden md:flex items-center gap-2">
                    <a
                        href="/login"
                        class="flex items-center justify-between gap-2 rounded-lg py-2 px-4 font-medium hover:bg-primary/90 bg-primary text-primary-foreground"
                    >
                        Create Account
                    </a>
                </div>
            </div>

            <!-- Mobile menu button -->
            <button
                class="cursor-pointer rounded-md md:hidden justify-self-end"
                id="menu-button"
            >
                <Menu id="menu-icon" class="size-5" />
                <X id="close-icon" class="size-5 hidden" />
                <span class="sr-only">Toggle menu</span>
            </button>
        </div>
    </div>

    <div id="mobile-menu" class="border-y border-border md:hidden hidden absolute top-full left-0 right-0 z-50 bg-background/95">
        <nav class="flex flex-col gap-4 p-4">
            <a
                href="/services"
                class="rounded-md px-4 py-2 text-muted-foreground transition-colors hover:bg-secondary hover:text-foreground"
            >
                Services
            </a>
            <a
                href="/about"
                class="rounded-md px-4 py-2 text-muted-foreground transition-colors hover:bg-secondary hover:text-foreground"
            >
                About
            </a>
            {
                !user && (
                    <div class="flex flex-col gap-2 pt-2">
                        <button class="cursor-pointer border border-border rounded-md p-2 w-full">
                            Log in
                        </button>
                        <button class="cursor-pointer bg-foreground text-background rounded-md p-2 w-full">
                            Sign up
                        </button>
                    </div>
                )
            }
        </nav>
    </div>
</header>

<script>
    const setupMenu = () => {
        const button = document.getElementById("menu-button");
        const menu = document.getElementById("mobile-menu");
        const menuIcon = document.getElementById("menu-icon");
        const closeIcon = document.getElementById("close-icon");

        if (button && menu) {
            const mobile_links = menu.querySelectorAll(
                'a[href="#services"], a[href="#mission"], a[href="#contact"]',
            );

            mobile_links.forEach((link) => {
                link.addEventListener("click", () => {
                    menu.classList.add("hidden");

                    if (!menuIcon || !closeIcon) {
                        return;
                    }

                    menuIcon.classList.remove("hidden");
                    closeIcon.classList.add("hidden");
                });
            });

            button.addEventListener("click", () => {
                menu.classList.toggle("hidden");

                if (!menuIcon || !closeIcon) {
                    return;
                }

                menuIcon.classList.toggle("hidden");
                closeIcon.classList.toggle("hidden");
            });
        }
    };

    setupMenu();
    document.addEventListener("astro:after-swap", setupMenu);
</script>
