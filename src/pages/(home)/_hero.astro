---
import {
    ArrowRight,
    Dumbbell,
    Calendar,
    Shield,
    Clapperboard,
} from "@lucide/astro";

const floatingIcons = [
    {
        icon: Dumbbell,
        color: "bg-chart-1",
        position: "top-20 left-[20%]",
        delay: "0s",
    },
    {
        icon: Calendar,
        color: "bg-chart-2",
        position: "top-32 right-[20%]",
        delay: "0.5s",
    },
    {
        icon: Shield,
        color: "bg-chart-3",
        position: "top-105 left-[10%]",
        delay: "1s",
    },
    {
        icon: Clapperboard,
        color: "bg-chart-4",
        position: "top-120 right-[15%]",
        delay: "1.5s",
    },
];
---

<section class="relative min-h-[80vh] overflow-hidden">
    <div class="max-w-450 mx-auto absolute inset-0">
        {/* Decorative background shapes */}
        <div class="absolute inset-0 -z-10" aria-hidden="true">
            <div
                class="absolute left-1/4 top-1/4 size-96 rounded-full bg-primary/5 blur-3xl"
            >
            </div>
            <div
                class="absolute bottom-1/4 right-1/4 size-96 rounded-full bg-accent/5 blur-3xl"
            >
            </div>
        </div>

        {/* Floating app icons */}
        {
            floatingIcons.map((item) => (
                <div
                    class={`absolute hidden lg:flex ${item.position} size-16 items-center justify-center rounded-2xl ${item.color} text-primary-foreground shadow-xl animate-bounce`}
                    style={{
                        animationDelay: item.delay,
                        animationDuration: "3s",
                    }}
                    aria-hidden="true"
                >
                    <item.icon class="size-7" />
                </div>
            ))
        }
    </div>

    <div
        class="mx-auto max-w-6xl px-4 py-24 sm:px-6 sm:py-32 lg:px-8 lg:py-40 relative"
    >
        <div class="flex flex-col items-center text-center">
            {/* Main heading */}
            <h1
                class="max-w-4xl text-balance text-4xl font-bold tracking-tight sm:text-5xl md:text-6xl lg:text-7xl"
            >
                <span class="text-foreground">Your digital life,</span>{" "}
                <span
                    class="bg-linear-to-r from-chart-1 to-chart-5 bg-clip-text text-transparent"
                    >finally connected.</span
                >
            </h1>

            {/* Subheading */}
            <p
                class="mt-8 max-w-2xl text-pretty text-lg leading-relaxed text-muted-foreground sm:text-xl"
            >
                We got tired of juggling a million apps. So we built something
                better. One account. Four awesome services. Zero headaches.
                Track your gains, plan your days, binge your shows - all in one
                place.
            </p>

            {/* CTA Buttons */}
            <div
                class="mt-10 grid grid-cols-1 items-center gap-4 sm:grid-cols-2"
            >
                <button
                    class="cursor-pointer flex items-center gap-2 hover:gap-3 bg-foreground text-background rounded-lg py-3 px-6 font-medium text-lg transition-all"
                >
                    Join the party
                    <ArrowRight class="size-5" />
                </button>
                <button
                    class="cursor-pointer rounded-lg py-3 px-6 border bg-input/30 font-medium text-lg"
                    >See what we built</button
                >
            </div>

            {/* Stats */}
            <div
                class="mt-10 grid grid-cols-1 md:grid-cols-3 flex-wrap gap-6 pt-10 sm:gap-8 justify-center sm:flex-row"
            >
                <div
                    class="flex flex-col items-center bg-card p-6 rounded-xl justify-center"
                >
                    <span class="text-3xl font-bold sm:text-5xl text-chart-3"
                        >4+</span
                    >
                    <span class="mt-3 text-sm font-medium text-muted-foreground"
                        >Apps that actually talk to each other</span
                    >
                </div>
                <div
                    class="flex flex-col items-center bg-card p-6 rounded-xl justify-center"
                >
                    <span class="text-3xl font-bold sm:text-5xl text-chart-2"
                        >1</span
                    >
                    <span class="mt-3 text-sm font-medium text-muted-foreground"
                        >Password to remember</span
                    >
                </div>
                <div
                    class="flex flex-col items-center bg-card p-6 rounded-xl justify-center"
                >
                    <span class="text-3xl font-bold sm:text-5xl text-chart-5"
                        >24/7</span
                    >
                    <span class="mt-3 text-sm font-medium text-muted-foreground"
                        >Always on, never sleeping</span
                    >
                </div>
            </div>
        </div>
    </div>
</section>
