---
import Layout from "@layouts/root.astro";
---

<Layout>
    <main class="flex-1 flex flex-col">
        <article
            class="mx-auto container max-w-2xl px-4 sm:px-6 lg:px-8 py-16"
        >
            <section>
                <a
                    href="/legal"
                    class="text-muted-foreground font-mono uppercase underline-offset-2 transition-all duration-300 hover:underline"
                >
                    Legal
                </a>
                <h1 class="my-4 text-4xl font-bold tracking-tight sm:text-4xl">
                    Terms of Service
                </h1>
                <p class="text-lg text-muted-foreground">
                    The terms governing your use of the Veblex ecosystem.
                </p>
                <p class="mt-4 text-muted-foreground">
                    Last updated: April 12, 2026
                </p>
            </section>

            <section id="acceptance-of-terms" class="mt-12">
                <h2 class="text-xl">Acceptance of Terms</h2>
                <p class="mt-2 text-muted-foreground">By accessing or using any Veblex service — including Veblex Gym, Calendar, and Auth — you agree to be bound by these terms. If you do not agree, you may not use the services.</p>
            </section>
        </article>
    </main>
</Layout>
