---
import { ArrowUpRight } from "@lucide/astro";

const services = [
    {
        name: "Veblex Gym",
        description:
            "Track and plan your exercises with powerful analytics. Create schedules, monitor your progress over time, and stay motivated with detailed insights into your fitness journey.",
        href: "https://gym.veblex.com",
        featured: false,
    },
    {
        name: "Veblex Calendar",
        description:
            "A comprehensive calendar solution that integrates seamlessly with all Veblex services. Schedule workouts, plan your entertainment, and stay organized effortlessly.",
        href: "https://calendar.veblex.com",
        featured: false,
    },
    {
        name: "Veblex Auth",
        description:
            "The backbone of the Veblex ecosystem. Secure single sign-on that lets you access all services with one account, and even authenticate with third-party applications.",
        href: "https://auth.veblex.com",
        featured: true,
    },
    {
        name: "Moviestix",
        description:
            "Your ultimate entertainment companion. Track what you're watching, manage your watchlist, see detailed progress on shows, and get recommendations from friends.",
        href: "https://www.moviestix.com",
        featured: false,
    },
];
---

<section id="services" class="border-t border-border bg-secondary/30">
    <div class="mx-auto max-w-7xl px-4 py-24 sm:px-6 lg:px-8">
        {/* Section header */}
        <div class="mx-auto max-w-2xl text-center">
            <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">
                Our Services
            </h2>
            <p class="mt-4 text-lg leading-relaxed text-muted-foreground">
                A growing ecosystem of interconnected applications designed to
                enhance every aspect of your digital life.
            </p>
        </div>

        {/* Services grid */}
        <div class="mt-16 grid gap-6 md:grid-cols-2">
            {
                services.map((service) => (
                    <div class="border rounded-md p-6 space-y-3 hover:border-accent/50 transition-all">
                        <p class="text-2xl font-semibold">{service.name}</p>
                        <p class="text-muted-foreground leading-relaxed">{service.description}</p>
                        <a class="flex gap-2 items-center border rounded-md w-fit py-2 px-4 mt-5" href={service.href} target="_blank" rel="noopener noreferrer">
                            Learn more <ArrowUpRight size={16} />
                        </a>
                    </div>
                ))
            }
        </div>
    </div>
</section>
