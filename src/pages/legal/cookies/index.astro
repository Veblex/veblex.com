---
import Layout from "@layouts/root.astro";
---

<Layout>
    <main class="flex-1 flex flex-col">
        <article
            class="mx-auto container max-w-2xl px-4 sm:px-6 lg:px-8 py-16"
        >
            <section>
                <a
                    href="/legal"
                    class="text-muted-foreground font-mono uppercase underline-offset-2 transition-all duration-300 hover:underline"
                >
                    Legal
                </a>
                <h1 class="my-4 text-4xl font-bold tracking-tight sm:text-4xl">
                    Cookie Policy
                </h1>
                <p class="text-lg text-muted-foreground">
                    How Veblex uses cookies and similar technologies.
                </p>
                <p class="mt-4 text-muted-foreground">
                    Last updated: April 12, 2026
                </p>
            </section>

            <section id="what-are-cookies" class="mt-12">
                <h2 class="text-xl">What Are Cookies</h2>
                <p class="mt-2 text-muted-foreground">Cookies are small text files stored on your device when you visit Veblex services. They help us remember preferences, analyze usage, and deliver a seamless experience across the ecosystem.</p>
            </section>
        </article>
    </main>
</Layout>
