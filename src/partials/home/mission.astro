---
import { Zap, Lock, Globe, Users, ArrowRight } from "@lucide/astro";

export const partial = true;

const values = [
    {
        name: "Seamless Integration",
        description:
            "All our services work together flawlessly, sharing data securely to give you a unified experience.",
        icon: Zap,
    },
    {
        name: "Privacy First",
        description:
            "Your data belongs to you. We employ industry-leading security practices to keep your information safe.",
        icon: Lock,
    },
    {
        name: "Always Accessible",
        description:
            "Access your ecosystem from anywhere, on any device. Your digital life travels with you.",
        icon: Globe,
    },
    {
        name: "Community Driven",
        description:
            "We build features our users want. Join our community and help shape the future of Veblex.",
        icon: Users,
    },
];
---

<section id="mission" class="border-t border-border">
    <div class="mx-auto container px-4 py-24 sm:px-6 lg:px-8">
        <div class="grid gap-12 lg:grid-cols-2 lg:gap-16">
            {/* Left column - Mission statement */}
            <div>
                <span class="text-muted-foreground font-mono uppercase text-sm"
                    >Mission</span
                >
                <h2 class="my-4 text-3xl font-bold tracking-tight sm:text-4xl">
                    An ecosystem, not just a product
                </h2>
                <div
                    class="space-y-4 text-lg leading-relaxed text-muted-foreground"
                >
                    <p>
                        At Veblex, we believe that technology should simplify
                        your life, not complicate it. Too often, we find
                        ourselves juggling dozens of apps, each with its own
                        login, its own data silos, and its own learning curve.
                    </p>
                    <p>
                        We set out to change that. Our mission is to create a
                        unified ecosystem of thoughtfully designed applications
                        that work together seamlessly - giving you back control
                        of your digital experience.
                    </p>
                    <p>
                        Whether you&apos;re tracking your fitness journey,
                        organizing your schedule, or discovering your next
                        favorite show, Veblex brings everything together under
                        one secure account, so you can focus on what matters
                        most: living your life.
                    </p>
                </div>

                <a
                    class="w-fit mt-6 cursor-pointer flex items-center justify-between gap-2 rounded-lg py-2 px-6 sm:px-8 hover:bg-primary/90 bg-primary text-primary-foreground"
                    href="#"
                >
                    Create Your Account
                    <ArrowRight class="size-5" />
                </a>
            </div>

            {/* Right column - Values */}
            <div
                class="grid gap-6 md:grid-cols-2 lg:grid-cols-1 xl:grid-cols-2"
            >
                {
                    values.map((value) => (
                        <div class="rounded-lg border border-primary/30 bg-card p-6 transition-colors duration-300 hover:border-primary/50">
                            <div class="flex size-10 items-center justify-center rounded-lg bg-secondary">
                                <value.icon class="size-5 text-foreground" />
                            </div>
                            <h3 class="mt-4 font-semibold">{value.name}</h3>
                            <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
                                {value.description}
                            </p>
                        </div>
                    ))
                }
            </div>
        </div>
    </div>
</section>
