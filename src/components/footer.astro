---
const year = new Date().getFullYear();

const footerLinks = {
    services: [
        { name: "Veblex Gym", href: "https://gym.veblex.com/"},
        { name: "Veblex Auth", href: "https://auth.veblex.com/"},
        { name: "Veblex Calendar", href: "https://calendar.veblex.com/"},
        { name: "Moviestix", href: "https://moviestix.com/"},
    ],
    company: [
        { name: "About", href: "#" },
        { name: "Careers", href: "#" },
        { name: "Press", href: "#" },
        { name: "Blog", href: "#" },
    ],
    resources: [
        { name: "Documentation", href: "#" },
        { name: "Help Center", href: "#" },
        { name: "API Reference", href: "#" },
        { name: "Status", href: "#" },
    ],
    legal: [
        { name: "Privacy Policy", href: "#" },
        { name: "Terms of Service", href: "#" },
        { name: "Cookie Policy", href: "#" },
    ],
};
---

<footer class="border-t border-border bg-background">
    <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
        <!-- Top bar -->
        <div class="flex flex-col lg:flex-row justify-between gap-6 gap-y-16">
            <!-- Brand -->
            <div>
                <a href="/" class="flex max-w-28">
                    <img src="veblex-logo_full-light.svg" alt="Veblex">
                </a>

                <p class="mt-4 max-w-xs text-sm leading-relaxed text-muted-foreground">
                    Your unified digital ecosystem. One account, endless possibilities.
                </p>

                <p class="mt-6 text-sm text-muted-foreground">
                    <a href="mailto:contact@veblex.com" class="transition-colors hover:text-foreground">
                        contact@veblex.com
                    </a>
                </p>
            </div>

            <div class="gap-12 sm:gap-16 lg:gap-20 flex flex-wrap xl:grid xl:grid-cols-4">
                <!-- Services -->
                <div class="flex flex-col basis-32">
                    <h3 class="text-sm font-semibold">Services</h3>
                    <ul class="mt-4 space-y-3">
                        {footerLinks.services.map((link) => (
                            <li>
                                <a href={link.href} class="text-sm text-muted-foreground transition-colors hover:text-foreground" target="_blank" rel="noopener noreferrer">
                                    {link.name}
                                </a>
                            </li>
                        ))}
                    </ul>
                </div>

                <!-- Company -->
                <div class="flex flex-col basis-32">
                    <h3 class="text-sm font-semibold">Company</h3>
                    <ul class="mt-4 space-y-3">
                        {footerLinks.company.map((link) => (
                            <li>
                                <a href={link.href} class="text-sm text-muted-foreground transition-colors hover:text-foreground" rel="noopener noreferrer">
                                    {link.name}
                                </a>
                            </li>
                        ))}
                    </ul>
                </div>

                <!-- Resources -->
                <div class="flex flex-col basis-32">
                    <h3 class="text-sm font-semibold">Resources</h3>
                    <ul class="mt-4 space-y-3">
                        {footerLinks.resources.map((link) => (
                            <li>
                                <a href={link.href} class="text-sm text-muted-foreground transition-colors hover:text-foreground" rel="noopener noreferrer">
                                    {link.name}
                                </a>
                            </li>
                        ))}
                    </ul>
                </div>

                <!-- Legal -->
                <div class="flex flex-col basis-32">
                    <h3 class="text-sm font-semibold">Legal</h3>
                    <ul class="mt-4 space-y-3">
                        {footerLinks.legal.map((link) => (
                            <li>
                                <a href={link.href} class="text-sm text-muted-foreground transition-colors hover:text-foreground" rel="noopener noreferrer">
                                    {link.name}
                                </a>
                            </li>
                        ))}
                    </ul>
                </div>
            </div>
        </div>

        <!-- Bottom bar -->
        <div
            class="mt-12 flex flex-col items-center justify-between gap-4 border-t border-border pt-8 sm:flex-row"
        >
            <p class="text-sm text-muted-foreground">
                &copy; {year} Veblex. All rights reserved.
            </p>

            <div class="flex items-center gap-4">
                <a
                    href="https://github.com/veblex/"
                    class="text-muted-foreground transition-colors hover:text-foreground"
                    aria-label="Veblex on GitHub"
                    target="_blank"
                    rel="noopener noreferrer"
                >
                    <svg
                        class="size-5"
                        fill="currentColor"
                        viewBox="0 0 24 24"
                        aria-hidden="true"
                    >
                        <path
                            fill-rule="evenodd"
                            d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
                            clip-rule="evenodd"></path>
                    </svg>
                </a>
            </div>
        </div>
    </div>
</footer>
