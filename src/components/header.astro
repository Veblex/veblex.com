---
import { Menu, X } from "@lucide/astro";

// Mock auth state - in a real app this would come from Veblex Auth
const mockUser = null; // Set to { name: "John Doe", email: "john@example.com", avatar: "" } to test logged in state
const user = mockUser;
---

<header
    class="sticky top-0 z-50 w-full border-b border-border/40 bg-background/95 backdrop-blur supports-backdrop-filter:bg-background/60"
>
    <div
        class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8"
    >
        <!-- Logo -->
        <a href="/" class="flex w-26">
            <img src="veblex-logo_full-light.svg" alt="Veblex" />
        </a>

        <!-- Desktop nav -->
        <nav class="hidden items-center gap-6 md:flex">
            <a
                href="#services"
                class="text-sm text-muted-foreground transition-colors hover:text-foreground"
                >Services</a
            >
            <a
                href="#mission"
                class="text-sm text-muted-foreground transition-colors hover:text-foreground"
                >Mission</a
            >
            <a
                href="#contact"
                class="text-sm text-muted-foreground transition-colors hover:text-foreground"
                >Contact</a
            >
        </nav>

        <!-- Auth buttons / profile -->
        <div class="flex items-center gap-4">
            {
                user ? (
                    <div>[PROFILE]</div>
                ) : (
                    <div class="hidden items-center gap-2 md:flex">
                        <button class="py-1 px-3 cursor-pointer rounded-md">
                            Log in
                        </button>
                        <button class="py-1 px-3 cursor-pointer rounded-md bg-foreground text-background">
                            Sign up
                        </button>
                    </div>
                )
            }
        </div>

        <!-- Mobile menu button -->
        <button class="cursor-pointer rounded-md md:hidden" id="menu-button">
            <Menu id="menu-icon" class="size-5" />
            <X id="close-icon" class="size-5 hidden" />
            <span class="sr-only">Toggle menu</span>
        </button>
    </div>

    <div id="mobile-menu" class="border-t border-border md:hidden hidden">
        <nav class="flex flex-col gap-4 p-4">
            <a
                href="#services"
                class="text-sm text-muted-foreground transition-colors hover:text-foreground"
            >
                Services
            </a>
            <a
                href="#mission"
                class="text-sm text-muted-foreground transition-colors hover:text-foreground"
            >
                Mission
            </a>
            <a
                href="#contact"
                class="text-sm text-muted-foreground transition-colors hover:text-foreground"
            >
                Contact
            </a>
            {
                !user && (
                    <div class="flex flex-col gap-2 pt-2">
                        <button class="cursor-pointer border border-border rounded-md p-2 w-full">
                            Log in
                        </button>
                        <button class="cursor-pointer bg-foreground text-background rounded-md p-2 w-full">
                            Sign up
                        </button>
                    </div>
                )
            }
        </nav>
    </div>
</header>

<script>
    const setupMenu = () => {
        const button = document.getElementById("menu-button");
        const menu = document.getElementById("mobile-menu");
        const menuIcon = document.getElementById("menu-icon");
        const closeIcon = document.getElementById("close-icon");

        if (button && menu) {
            const mobile_links = menu.querySelectorAll(
                'a[href="#services"], a[href="#mission"], a[href="#contact"]',
            );

            mobile_links.forEach((link) => {
                link.addEventListener("click", () => {
                    menu.classList.add("hidden");

                    if (!menuIcon || !closeIcon) {
                        return;
                    }

                    menuIcon.classList.remove("hidden");
                    closeIcon.classList.add("hidden");
                });
            });

            button.addEventListener("click", () => {
                menu.classList.toggle("hidden");

                if (!menuIcon || !closeIcon) {
                    return;
                }

                menuIcon.classList.toggle("hidden");
                closeIcon.classList.toggle("hidden");
            });
        }
    };

    setupMenu();
    document.addEventListener("astro:after-swap", setupMenu);
</script>
