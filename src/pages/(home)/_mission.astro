---
import { Zap, Lock, Globe, Users } from "@lucide/astro"

const values = [
  {
    name: "Seamless Integration",
    description: "All our services work together flawlessly, sharing data securely to give you a unified experience.",
    icon: Zap,
  },
  {
    name: "Privacy First",
    description: "Your data belongs to you. We employ industry-leading security practices to keep your information safe.",
    icon: Lock,
  },
  {
    name: "Always Accessible",
    description: "Access your ecosystem from anywhere, on any device. Your digital life travels with you.",
    icon: Globe,
  },
  {
    name: "Community Driven",
    description: "We build features our users want. Join our community and help shape the future of Veblex.",
    icon: Users,
  },
]
---

    <section id="mission" class="border-t border-border">
      <div class="mx-auto max-w-7xl px-4 py-24 sm:px-6 lg:px-8">
        <div class="grid gap-12 lg:grid-cols-2 lg:gap-16">
          {/* Left column - Mission statement */}
          <div>
            <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">Our Mission</h2>
            <div class="mt-6 space-y-4 text-lg leading-relaxed text-muted-foreground">
              <p>
                At Veblex, we believe that technology should simplify your life, not complicate it. 
                Too often, we find ourselves juggling dozens of apps, each with its own login, its own 
                data silos, and its own learning curve.
              </p>
              <p>
                We set out to change that. Our mission is to create a unified ecosystem of thoughtfully 
                designed applications that work together seamlessly - giving you back control of your 
                digital experience.
              </p>
              <p>
                Whether you&apos;re tracking your fitness journey, organizing your schedule, or discovering 
                your next favorite show, Veblex brings everything together under one secure account, 
                so you can focus on what matters most: living your life.
              </p>
            </div>
          </div>

          {/* Right column - Values */}
          <div class="grid gap-6 sm:grid-cols-2">
            {values.map((value) => (
              <div class="group rounded-lg border border-border bg-card p-6 transition-colors hover:border-accent/50">
                <div class="flex size-10 items-center justify-center rounded-lg bg-secondary">
                  <value.icon class="size-5 text-foreground" />
                </div>
                <h3 class="mt-4 font-semibold">{value.name}</h3>
                <p class="mt-2 text-sm leading-relaxed text-muted-foreground">{value.description}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
